{
  "effortLevel": "medium",
  "tui": "fullscreen",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/enforce-commit-skill.py"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/require-git-land-todo-tools.py"
          }
        ]
      }
    ]
  }
}
